# =============================================================================
# Stock Control API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# =============================================================================

# Application
APP_NAME=stock-control-api
APP_ENV=development        # development | production
DEBUG=true                 # true logs SQL queries — set false in production

# Server
HOST=0.0.0.0
PORT=8000

# Database (Phase 2)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://stockcontrol:stockcontrol123@localhost:5432/stockcontroldb

# Auth (Phase 4 — leave blank for now)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
