# =============================================================================
# Environment & Secrets — MOST IMPORTANT
# =============================================================================
# These files contain passwords, API keys, database URLs.
# Committing secrets is the #1 cause of security breaches at startups.
.env
.env.local
.env.production
.env.*.local

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# =============================================================================
# Virtual Environment
# =============================================================================
venv/
.venv/
env/

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# =============================================================================
# Operating System
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Testing & Coverage
# =============================================================================
htmlcov/
.coverage
.coverage.*
.pytest_cache/

# =============================================================================
# Database (local dev)
# =============================================================================
*.db
*.sqlite3
